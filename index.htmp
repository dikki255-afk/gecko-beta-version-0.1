<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Stalking Predator with Fixed Camera & Joystick</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body, html { width: 100%; height: 100%; overflow: hidden; background: #050505; position: relative; }
        canvas { display: block; width: 100vw; height: 100vh; }

        /* --- STYLING VIRTUAL JOYSTICK --- */
        #joystickContainer {
            position: absolute;
            bottom: 50px;
            left: 50px;
            width: 120px;
            height: 120px;
            background: rgba(255, 255, 255, 0.03);
            border: 2px solid #ff003c;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10;
            touch-action: none;
            box-shadow: 0 0 15px rgba(255, 0, 60, 0.2);
        }
        #joystickStick {
            width: 50px;
            height: 50px;
            background: #ff003c;
            border-radius: 50%;
            box-shadow: 0 0 20px #ff003c;
            pointer-events: none;
        }

        /* --- STYLING TOMBOL ZOOM UNTUK ANDROID --- */
        #zoomControls {
            position: absolute;
            top: 20px;
            right: 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            z-index: 10;
        }
        .zoom-btn {
            width: 50px;
            height: 50px;
            background: rgba(0, 0, 0, 0.6);
            border: 2px solid #ff003c;
            color: #ff003c;
            font-size: 24px;
            font-weight: bold;
            border-radius: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            user-select: none;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(255, 0, 60, 0.3);
        }
        .zoom-btn:active {
            background: #ff003c;
            color: #050505;
        }
    </style>
</head>
<body>

    <div id="joystickContainer">
        <div id="joystickStick"></div>
    </div>

    <div id="zoomControls">
        <div class="zoom-btn" id="zoomInBtn">+</div>
        <div class="zoom-btn" id="zoomOutBtn"></div>
    </div>

    <canvas id="geckoCanvas"></canvas>

<script>
// --- 1. CETAKAN PELURU KUNING ---
class Bullet {
  constructor(x, y, sudut) {
    this.x = x;
    this.y = y;
    this.speed = 5; 
    this.vx = Math.cos(sudut) * this.speed;
    this.vy = Math.sin(sudut) * this.speed;
    this.radius = 4; 
  }

  update() {
    this.x += this.vx;
    this.y += this.vy;
  }

  draw(ctx) {
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
    ctx.fillStyle = "yellow"; 
    ctx.fill();
    ctx.closePath();
  }
}

// --- 2. CETAKAN PEMBURU DENGAN AI PINTAR ---
class Hunter {
  constructor(x, y) {
    this.x = x;
    this.y = y;
    this.radius = 12; 
    this.color = "blue"; 
    this.lariSpeed = 2.2;  
    this.intaiSpeed = 0.8; 
    this.shootCooldown = 0; 
  }

  draw(ctx) {
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
    ctx.fillStyle = this.color;
    ctx.fill();
    ctx.closePath();
  }

  update(kepalaKadal, kadalBergerak, daftarPeluru) {
    let dx = kepalaKadal.x - this.x;
    let dy = kepalaKadal.y - this.y;
    let jarak = Math.sqrt(dx * dx + dy * dy);
    let sudut = Math.atan2(dy, dx);

    if (this.shootCooldown > 0) {
      this.shootCooldown--;
    }

    if (jarak < 200) {
      this.color = "orange"; 
      this.x -= Math.cos(sudut) * this.lariSpeed; 
      this.y -= Math.sin(sudut) * this.lariSpeed;
    } 
    else if (jarak < 600) {
      this.color = "blue"; 

      if (!kadalBergerak) {
        this.x += Math.cos(sudut) * this.intaiSpeed; 
        this.y += Math.sin(sudut) * this.intaiSpeed;
      }

      if (this.shootCooldown === 0) {
        daftarPeluru.push(new Bullet(this.x, this.y, sudut));
        this.shootCooldown = 90; 
      }
    }
  }
}

// --- 3. INISIALISASI GAME ---
const canvas = document.getElementById("geckoCanvas");
const ctx = canvas.getContext("2d");

let zoomLevel = 0.6; 
const minZoom = 0.25;
const maxZoom = 2.0;

let pemburu1 = new Hunter(100, 100);
let listPeluru = [];

// --- LOGIKA KONTROL VIRTUAL JOYSTICK ---
const joyContainer = document.getElementById("joystickContainer");
const joyStick = document.getElementById("joystickStick");
let joystick = { active: false, angle: 0 };

function handleJoystick(clientX, clientY) {
    const rect = joyContainer.getBoundingClientRect();
    const centerX = rect.left + rect.width / 2;
    const centerY = rect.top + rect.height / 2;
    
    let dx = clientX - centerX;
    let dy = clientY - centerY;
    let jarak = Math.sqrt(dx * dx + dy * dy);
    const maxRadius = rect.width / 2;

    if (jarak > maxRadius) {
        dx = (dx / jarak) * maxRadius;
        dy = (dy / jarak) * maxRadius;
        jarak = maxRadius;
    }

    joyStick.style.transform = `translate(${dx}px, ${dy}px)`;
    
    if (jarak > 8) {
        joystick.active = true;
        joystick.angle = Math.atan2(dy, dx);
    } else {
        joystick.active = false;
    }
}

function resetJoystick() {
    joyStick.style.transform = `translate(0px, 0px)`;
    joystick.active = false;
}

joyContainer.addEventListener("touchstart", (e) => {
    e.preventDefault();
    handleJoystick(e.touches[0].clientX, e.touches[0].clientY);
});
joyContainer.addEventListener("touchmove", (e) => {
    e.preventDefault();
    handleJoystick(e.touches[0].clientX, e.touches[0].clientY);
});
joyContainer.addEventListener("touchend", resetJoystick);

let isDraggingJoy = false;
joyContainer.addEventListener("mousedown", (e) => {
    isDraggingJoy = true;
    handleJoystick(e.clientX, e.clientY);
});
window.addEventListener("mousemove", (e) => {
    if (isDraggingJoy) handleJoystick(e.clientX, e.clientY);
});
window.addEventListener("mouseup", () => {
    isDraggingJoy = false;
    resetJoystick();
});

// --- LOGIKA ZOOM ---
window.addEventListener("wheel", (e) => {
    if (e.deltaY < 0) zoomLevel = Math.min(zoomLevel + 0.05, maxZoom);
    else zoomLevel = Math.max(zoomLevel - 0.05, minZoom);
});

document.getElementById("zoomInBtn").addEventListener("click", () => {
    zoomLevel = Math.min(zoomLevel + 0.15, maxZoom);
});
document.getElementById("zoomOutBtn").addEventListener("click", () => {
    zoomLevel = Math.max(zoomLevel - 0.15, minZoom);
});

let initialPinchDist = null;
let initialZoom = 1.0;

window.addEventListener("touchstart", (e) => {
    if (e.touches.length === 2) {
        initialPinchDist = Math.hypot(
            e.touches[0].clientX - e.touches[1].clientX,
            e.touches[0].clientY - e.touches[1].clientY
        );
        initialZoom = zoomLevel;
    }
});
window.addEventListener("touchmove", (e) => {
    if (e.touches.length === 2 && initialPinchDist) {
        let currentDist = Math.hypot(
            e.touches[0].clientX - e.touches[1].clientX,
            e.touches[0].clientY - e.touches[1].clientY
        );
        let factor = currentDist / initialPinchDist;
        zoomLevel = Math.max(minZoom, Math.min(maxZoom, initialZoom * factor));
    }
});
window.addEventListener("touchend", (e) => {
    if (e.touches.length < 2) initialPinchDist = null;
});


function resizeCanvas() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
}
window.addEventListener("resize", resizeCanvas);
resizeCanvas();

const jumlahSegmen = 18; 
const panjangSegmen = 12; 
let segmen = [];
// PERBAIKAN: Kadal langsung dilahirkan memanjang ke kiri agar tidak menumpuk memicu error
for (let i = 0; i < jumlahSegmen; i++) {
    segmen.push({ x: (canvas.width / 2) - (i * panjangSegmen), y: canvas.height / 2 });
}

let waktuGlobal = 0; 
const panjangPaha = 45;
const panjangBetis = 50;

let dataKaki = [
    { nama: "Depan Kiri", segmenBody: 2, group: 0, sign: -1, localX: 35, localY: -65, xTanah: 0, yTanah: 0, xAsal: 0, yAsal: 0, xTarget: 0, yTarget: 0, stepProgress: 1 },
    { nama: "Depan Kanan", segmenBody: 2, group: 1, sign: 1, localX: 35, localY: 65, xTanah: 0, yTanah: 0, xAsal: 0, yAsal: 0, xTarget: 0, yTarget: 0, stepProgress: 1 },
    { nama: "Belakang Kiri", segmenBody: 10, group: 1, sign: 1, localX: -20, localY: -70, xTanah: 0, yTanah: 0, xAsal: 0, yAsal: 0, xTarget: 0, yTarget: 0, stepProgress: 1 },
    { nama: "Belakang Kanan", segmenBody: 10, group: 0, sign: -1, localX: -20, localY: 70, xTanah: 0, yTanah: 0, xAsal: 0, yAsal: 0, xTarget: 0, yTarget: 0, stepProgress: 1 }
];

let stepGroupAktif = 0; 

// PERBAIKAN: Posisi cakar tanah disesuaikan dengan posisi badan awal agar tidak tertarik ke tengah
dataKaki.forEach(kaki => {
    let pahaX = segmen[kaki.segmenBody].x;
    let pahaY = segmen[kaki.segmenBody].y;
    kaki.xTanah = kaki.xAsal = kaki.xTarget = pahaX + kaki.localX;
    kaki.yTanah = kaki.yAsal = kaki.yTarget = pahaY + kaki.localY;
});

// PERBAIKAN: Pengaman rumus matematika Inverse Kinematics dari pembagian angka 0 (Anti-NaN)
function hitungIK(hipX, hipY, footX, footY, L1, L2, sign) {
    let dx = footX - hipX;
    let dy = footY - hipY;
    let dist = Math.sqrt(dx*dx + dy*dy);
    
    if (dist < 0.1) {
        return { x: hipX + L1, y: hipY }; // Kembalikan koordinat default jika jaraknya nol
    }
    
    dist = Math.min(dist, L1 + L2 - 0.01); 

    let angleToFoot = Math.atan2(dy, dx);
    let cosTheta = (L1*L1 + dist*dist - L2*L2) / (2 * L1 * dist);
    cosTheta = Math.max(-1, Math.min(1, cosTheta));
    let theta = Math.acos(cosTheta);
    
    let kneeAngle = angleToFoot + (sign * theta);
    
    return {
        x: hipX + Math.cos(kneeAngle) * L1,
        y: hipY + Math.sin(kneeAngle) * L1
    };
}

// --- 4. ENGINE ANIMASI LOOP UTAMA ---
function updateAnimasi() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    let kadalBergerak = joystick.active;
    let arahX = Math.cos(joystick.angle);
    let arahY = Math.sin(joystick.angle);

    pemburu1.update(segmen[0], kadalBergerak, listPeluru);
    for (let i = listPeluru.length - 1; i >= 0; i--) {
        listPeluru[i].update();
    }

    let setengahLebarDunia = (canvas.width / 2) / zoomLevel;
    let setengahTinggiDunia = (canvas.height / 2) / zoomLevel;
    let minX = segmen[0].x - setengahLebarDunia;
    let maxX = segmen[0].x + setengahLebarDunia;
    let minY = segmen[0].y - setengahTinggiDunia;
    let maxY = segmen[0].y + setengahTinggiDunia;

    // MATRIKS TRANSFORMAI KAMERA INTEGRASI ZOOM
    ctx.save();
    ctx.translate(canvas.width / 2, canvas.height / 2); 
    ctx.scale(zoomLevel, zoomLevel);                     
    ctx.translate(-segmen[0].x, -segmen[0].y);           

    // 1. Gambar Grid Map
    ctx.strokeStyle = "#14141f";
    ctx.lineWidth = 1 / zoomLevel; 
    let gridSize = 100;
    let startX = Math.floor(minX / gridSize) * gridSize;
    let endX = Math.ceil(maxX / gridSize) * gridSize;
    let startY = Math.floor(minY / gridSize) * gridSize;
    let endY = Math.ceil(maxY / gridSize) * gridSize;
    
    for (let x = startX; x <= endX; x += gridSize) {
        ctx.beginPath(); ctx.moveTo(x, minY); ctx.lineTo(x, maxY); ctx.stroke();
    }
    for (let y = startY; y <= endY; y += gridSize) {
        ctx.beginPath(); ctx.moveTo(minX, y); ctx.lineTo(maxX, y); ctx.stroke();
    }

    // 2. Gambar Pemburu dan Peluru
    pemburu1.draw(ctx);
    for (let i = listPeluru.length - 1; i >= 0; i--) {
        listPeluru[i].draw(ctx);
        if (listPeluru[i].x < minX - 200 || listPeluru[i].x > maxX + 200 || 
            listPeluru[i].y < minY - 200 || listPeluru[i].y > maxY + 200) {
            listPeluru.splice(i, 1);
        }
    }

    // --- LOGIKA BERGERAK KADAL ---
    if (kadalBergerak) { 
        waktuGlobal += 0.15; 
        
        let efekLunge = Math.max(0, Math.sin(waktuGlobal * 2)) * 1.5;
        let amplitudo = 2.0; 
        let ayunanSampingX = -arahY * Math.sin(waktuGlobal) * amplitudo;
        let ayunanSampingY = arahX * Math.sin(waktuGlobal) * amplitudo;

        let kecepatan = 4.0 + efekLunge; 
        segmen[0].x += (arahX * kecepatan) + ayunanSampingX;
        segmen[0].y += (arahY * kecepatan) + ayunanSampingY;
    }

    for (let i = 1; i < jumlahSegmen; i++) {
        let dx = segmen[i-1].x - segmen[i].x;
        let dy = segmen[i-1].y - segmen[i].y;
        let jarak = Math.sqrt(dx*dx + dy*dy);
        if (jarak > panjangSegmen) {
            let rasio = panjangSegmen / jarak;
            segmen[i].x = segmen[i-1].x - dx * rasio;
            segmen[i].y = segmen[i-1].y - dy * rasio;
        }
    }

    let isStepping = dataKaki.some(k => k.stepProgress < 1.0);

    if (!isStepping && kadalBergerak) { 
        let butuhLangkah = false;
        
        dataKaki.forEach(k => {
            if (k.group === stepGroupAktif) {
                let pahaX = segmen[k.segmenBody].x;
                let pahaY = segmen[k.segmenBody].y;
                let dxBody = segmen[k.segmenBody-1].x - segmen[k.segmenBody].x;
                let dyBody = segmen[k.segmenBody-1].y - segmen[k.segmenBody].y;
                let sudutBody = Math.atan2(dyBody, dxBody);
                
                let idealX = pahaX + k.localX * Math.cos(sudutBody) - k.localY * Math.sin(sudutBody);
                let idealY = pahaY + k.localX * Math.sin(sudutBody) + k.localY * Math.cos(sudutBody);
                
                let jarakKeIdeal = Math.sqrt((k.xTarget - idealX)**2 + (k.yTarget - idealY)**2);
                
                if (jarakKeIdeal > 55) butuhLangkah = true;
            }
        });

        if (butuhLangkah) {
            dataKaki.forEach(k => {
                if (k.group === stepGroupAktif) {
                    k.stepProgress = 0.0;
                    k.xAsal = k.xTanah;
                    k.yAsal = k.yTanah;
                    
                    let pahaX = segmen[k.segmenBody].x;
                    let pahaY = segmen[k.segmenBody].y;
                    let dxBody = segmen[k.segmenBody-1].x - segmen[k.segmenBody].x;
                    let dyBody = segmen[k.segmenBody-1].y - segmen[k.segmenBody].y;
                    let sudutBody = Math.atan2(dyBody, dxBody);
                    
                    let idealX = pahaX + k.localX * Math.cos(sudutBody) - k.localY * Math.sin(sudutBody);
                    let idealY = pahaY + k.localX * Math.sin(sudutBody) + k.localY * Math.cos(sudutBody);
                    
                    k.xTarget = idealX + Math.cos(sudutBody) * 45;
                    k.yTarget = idealY + Math.sin(sudutBody) * 45;
                }
            });
            stepGroupAktif = 1 - stepGroupAktif; 
        }
    }

    dataKaki.forEach(kaki => {
        if (kaki.stepProgress < 1.0) {
            kaki.stepProgress += 0.12; 
            let t = Math.min(kaki.stepProgress, 1.0);
            let easeT = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
            
            kaki.xTanah = kaki.xAsal + (kaki.xTarget - kaki.xAsal) * easeT;
            kaki.yTanah = kaki.yAsal + (kaki.yTarget - kaki.yAsal) * easeT;
            
            kaki.yTanah -= Math.sin(Math.PI * t) * 35; 
        }

        let pahaX = segmen[kaki.segmenBody].x;
        let pahaY = segmen[kaki.segmenBody].y;

        let lutut = hitungIK(pahaX, pahaY, kaki.xTanah, kaki.yTanah, panjangPaha, panjangBetis, kaki.sign);

        ctx.strokeStyle = "#ff003c"; 
        ctx.lineWidth = 6;
        ctx.lineJoin = "round";
        ctx.lineCap = "round";
        
        ctx.beginPath();
        ctx.moveTo(pahaX, pahaY);
        ctx.lineTo(lutut.x, lutut.y);
        ctx.lineTo(kaki.xTanah, kaki.yTanah);
        ctx.stroke();

        ctx.strokeStyle = "#111"; 
        ctx.lineWidth = 3;
        ctx.beginPath();
        ctx.moveTo(pahaX, pahaY);
        ctx.lineTo(lutut.x, lutut.y);
        ctx.lineTo(kaki.xTanah, kaki.yTanah);
        ctx.stroke();

        let isKiri = kaki.localY < 0; 
        let dxBodyKaki = segmen[kaki.segmenBody-1].x - segmen[kaki.segmenBody].x;
        let dyBodyKaki = segmen[kaki.segmenBody-1].y - segmen[kaki.segmenBody].y;
        let sudutBodyKaki = Math.atan2(dyBodyKaki, dxBodyKaki);
        
        let splayOffset = isKiri ? -0.4 : 0.4;
        let flexOffset = 0;
        if (kaki.stepProgress < 1.0) {
            let t = kaki.stepProgress;
            flexOffset = Math.sin(Math.PI * t) * (isKiri ? 0.8 : -0.8);
        }

        let sudutTelapak = sudutBodyKaki + splayOffset + flexOffset;

        ctx.strokeStyle = "#ff003c";
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        for (let j = -1; j <= 1; j++) {
            let sudutJari = sudutTelapak + (j * 0.35); 
            let panjangCakar = 16 + (j === 0 ? 5 : 0); 
            let ujungJariX = kaki.xTanah + Math.cos(sudutJari) * panjangCakar;
            let ujungJariY = kaki.yTanah + Math.sin(sudutJari) * panjangCakar;
            ctx.moveTo(kaki.xTanah, kaki.yTanah);
            ctx.lineTo(ujungJariX, ujungJariY);
        }
        ctx.stroke();
    });

    for (let i = 0; i < jumlahSegmen; i++) {
        let ukuran = 3;
        if (i === 0) ukuran = 15; 
        else if (i === 1) ukuran = 12; 
        else if (i < 9) ukuran = 17 - (i * 0.3);  
        else ukuran = Math.max(15 - (i * 0.8), 2); 
        
        ctx.fillStyle = "#111";
        ctx.strokeStyle = "#ff003c";
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(segmen[i].x, segmen[i].y, ukuran, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();

        if (i > 1 && i < jumlahSegmen - 2) {
            let dxSpike = segmen[i-1].x - segmen[i].x;
            let dySpike = segmen[i-1].y - segmen[i].y;
            let sudutSpike = Math.atan2(dySpike, dxSpike);
            
            let ukuranDuri = ukuran * 1.6;
            ctx.fillStyle = "#ff003c";
            ctx.beginPath();
            ctx.moveTo(segmen[i].x + Math.cos(sudutSpike + Math.PI/2) * (ukuran*0.6), segmen[i].y + Math.sin(sudutSpike + Math.PI/2) * (ukuran*0.6));
            ctx.lineTo(segmen[i].x + Math.cos(sudutSpike - Math.PI/2) * (ukuran*0.6), segmen[i].y + Math.sin(sudutSpike - Math.PI/2) * (ukuran*0.6));
            ctx.lineTo(segmen[i].x - Math.cos(sudutSpike) * ukuranDuri, segmen[i].y - Math.sin(sudutSpike) * ukuranDuri);
            ctx.fill();
        }
    }

    let sudutKepala = joystick.active ? joystick.angle : Math.atan2(segmen[0].y - segmen[1].y, segmen[0].x - segmen[1].x);
    
    ctx.fillStyle = "#ff0000";
    ctx.beginPath();
    ctx.arc(segmen[0].x + Math.cos(sudutKepala - 0.7) * 7, segmen[0].y + Math.sin(sudutKepala - 0.7) * 7, 3.5, 0, Math.PI * 2);
    ctx.fill();
    ctx.beginPath();
    ctx.arc(segmen[0].x + Math.cos(sudutKepala + 0.7) * 7, segmen[0].y + Math.sin(sudutKepala + 0.7) * 7, 3.5, 0, Math.PI * 2);
    ctx.fill();

    ctx.strokeStyle = "#000";
    ctx.lineWidth = 1.5;
    
    let mataKiriX = segmen[0].x + Math.cos(sudutKepala - 0.7) * 7;
    let mataKiriY = segmen[0].y + Math.sin(sudutKepala - 0.7) * 7;
    ctx.beginPath();
    ctx.moveTo(mataKiriX + Math.cos(sudutKepala + Math.PI/2) * 2.5, mataKiriY + Math.sin(sudutKepala + Math.PI/2) * 2.5);
    ctx.lineTo(mataKiriX - Math.cos(sudutKepala + Math.PI/2) * 2.5, mataKiriY - Math.sin(sudutKepala + Math.PI/2) * 2.5);
    ctx.stroke();

    let mataKananX = segmen[0].x + Math.cos(sudutKepala + 0.7) * 7;
    let mataKananY = segmen[0].y + Math.sin(sudutKepala + 0.7) * 7;
    ctx.beginPath();
    ctx.moveTo(mataKananX + Math.cos(sudutKepala + Math.PI/2) * 2.5, mataKananY + Math.sin(sudutKepala + Math.PI/2) * 2.5);
    ctx.lineTo(mataKananX - Math.cos(sudutKepala + Math.PI/2) * 2.5, mataKananY - Math.sin(sudutKepala + Math.PI/2) * 2.5);
    ctx.stroke();

    ctx.restore(); 

    requestAnimationFrame(updateAnimasi);
}

updateAnimasi();
</script>

</body>
</html>
